# ===========================================
# NCTIRS Environment Variables
# Copy this file: cp .env.example .env.local
# ===========================================

# --- Database (Turso / LibSQL) ---
# Get these from https://turso.tech dashboard
DATABASE_URL=libsql://your-database-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# --- Application ---
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_APP_URL=https://your-app.up.railway.app
NEXT_PUBLIC_SOCKET_URL=https://your-app.up.railway.app

# --- Real-time (Ably) — Optional ---
NEXT_PUBLIC_ABLY_API_KEY=your-ably-api-key

# --- Webhooks — Optional ---
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
GITHUB_WEBHOOK_SECRET=

# --- API Keys — Optional ---
OPENCLAW_API_KEY=
